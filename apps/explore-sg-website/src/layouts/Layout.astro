---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Explore Singapore — AI Trip Planner | 100+ Curated Places, Guides & Itineraries',
  description = 'Plan your perfect Singapore trip with our free AI-powered planner. 100+ curated places, interactive maps, personalised itineraries, and local guides — right in your browser.'
} = Astro.props;

const siteUrl = 'https://exploresg.info';
const ogImage = `${siteUrl}/og-image.jpg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Singapore trip planner, AI itinerary Singapore, things to do Singapore, Singapore guide, hawker food Singapore, best cafes Singapore, tourist attractions Singapore, plan Singapore trip online, Singapore tourism, free travel planner" />
    <meta name="author" content="Explore Singapore" />
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Explore Singapore" />
    <meta property="og:locale" content="en_SG" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={siteUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- GEO Tags -->
    <meta name="geo.region" content="SG" />
    <meta name="geo.placename" content="Singapore" />
    <meta name="geo.position" content="1.3521;103.8198" />
    <meta name="ICBM" content="1.3521, 103.8198" />

    <!-- Language / Locale -->
    <meta property="og:locale" content="en_SG" />
    <meta http-equiv="content-language" content="en-sg" />
    <link rel="alternate" hreflang="en" href={siteUrl} />

    <!-- App Meta -->
    <meta name="application-name" content="Explore Singapore" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Structured Data — WebApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Explore Singapore",
      "url": "https://app.exploresg.info",
      "applicationCategory": "TravelApplication",
      "browserRequirements": "Requires a modern web browser",
      "description": description,
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "SGD"
      }
    })} />

    <!-- Structured Data — Local Business / Tourism -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristInformationCenter",
      "name": "Explore Singapore App",
      "description": "AI-powered travel companion for discovering Singapore",
      "url": siteUrl,
      "areaServed": {
        "@type": "City",
        "name": "Singapore",
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 1.3521,
          "longitude": 103.8198
        }
      },
      "availableLanguage": "English"
    })} />

    <!-- Structured Data — FAQ for AEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is Explore Singapore?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Explore Singapore is a free AI-powered trip planner that helps you discover 100+ curated places, plan personalised itineraries, and explore interactive maps — all in your browser with no sign-up required."
          }
        },
        {
          "@type": "Question",
          "name": "Is Explore Singapore free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, Explore Singapore is completely free. No account, no sign-up, no hidden fees — just open the website and start planning your trip."
          }
        },
        {
          "@type": "Question",
          "name": "How does the AI trip planner work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Tell us your interests (food, culture, nature), how many days you have, and your budget. The AI generates a personalised day-by-day itinerary with timings, routes, and restaurant recommendations that you can customise."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need to create an account?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Explore Singapore works instantly in your browser — no downloads, no sign-ups. Your itinerary is saved locally so you can come back anytime."
          }
        }
      ]
    })} />

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  </head>
  <body class="overflow-x-hidden">
    <slot />
  </body>
</html>
