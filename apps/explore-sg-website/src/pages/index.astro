---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// Fetch live data from Supabase
const { data: recommendations } = await supabase
  .from('recommendations')
  .select('headline, tag, description, image_url, recommendation_items(count)')
  .order('sort_order');

const { data: featuredPlaces } = await supabase
  .from('places')
  .select('name, image_url, rating, tags, address')
  .eq('is_featured', true)
  .limit(6);

const { count: placesCount } = await supabase
  .from('places')
  .select('*', { count: 'exact', head: true });

const guidesCount = recommendations?.length ?? 0;
---

<Layout>
  <main>
  <!-- Nav -->
  <nav id="main-nav" aria-label="Main navigation" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
      <span class="nav-text text-[15px] tracking-tight text-white transition-colors duration-300">Explore <strong class="font-extrabold text-[#EF3340]">Singapore</strong></span>
      <div class="flex items-center gap-6">
        <a href="#features" class="nav-link text-[13px] text-white/60 hover:text-white transition-colors hidden md:block">Features</a>
        <a href="#guides" class="nav-link text-[13px] text-white/60 hover:text-white transition-colors hidden md:block">Guides</a>
        <a href="#download" class="nav-btn bg-white text-[#222] text-[13px] font-semibold px-4 py-2 rounded-full hover:opacity-80 transition-all">
          Get the App
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Hero text with background image -->
    <div class="relative min-h-[90vh] flex items-center">
      <div class="absolute inset-0">
        <img src="/hero-bg.jpg" alt="Singapore" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black/50"></div>
      </div>
      <div class="relative z-10 max-w-[1200px] mx-auto px-6 py-40">
        <div>
          <div class="animate-fade-up inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 mb-6 backdrop-blur-sm">
            <span class="w-2 h-2 rounded-full bg-[#EF3340] animate-pulse"></span>
            <span class="text-white text-[12px] font-semibold">AI-Powered Travel Companion</span>
          </div>
          <h1 class="animate-fade-up delay-1 text-[clamp(2.5rem,6vw,4.5rem)] font-extrabold leading-[1.05] tracking-tight text-white">
            The smartest way to explore <span class="text-[#EF3340]">Singapore</span>
          </h1>
          <p class="animate-fade-up delay-2 mt-6 text-white/70 text-lg md:text-xl leading-relaxed max-w-xl">
            AI-generated itineraries. {placesCount}+ curated places. {guidesCount} local guides. Works completely offline.
          </p>
          <div class="animate-fade-up delay-3 mt-10 flex gap-4 items-center">
            <a href="#download" class="bg-white text-[--color-text-primary] font-semibold px-7 py-3.5 rounded-full text-[15px] hover:bg-white/90 transition-all hover:shadow-lg">
              Download for iOS
            </a>
            <span class="text-[13px] text-white/50">Free on TestFlight</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Phone mockups below hero -->
    <div class="bg-white pt-16 pb-16">
    <div class="max-w-[1200px] mx-auto px-6">

      <!-- App Preview — Stacked phones -->
      <div class="animate-fade-up delay-4 mt-20 relative h-[500px] md:h-[650px] flex items-center justify-center">
        <!-- Background phone (detail view) -->
        <img
          src="/mockup-detail.png"
          alt="Place detail screen"
          class="absolute right-[5%] md:right-[15%] top-8 w-[260px] md:w-[320px] animate-float-delayed"
        />
        <!-- Main phone (home screen) -->
        <img
          src="/mockup-home.png"
          alt="Explore SG home screen"
          class="absolute left-[5%] md:left-[15%] top-0 w-[280px] md:w-[360px] animate-float z-10 drop-shadow-2xl"
        />
      </div>
    </div>
    </div>
  </section>

  <!-- Scrolling tags -->
  <section class="py-6 overflow-hidden mt-8">
    <div class="animate-marquee flex gap-4 whitespace-nowrap">
      {[...Array(2)].map(() => (
        <>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">🍜</span>Hawker Food</span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">☕</span>Cafes</span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">🌳</span>Parks</span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">🍸</span>Nightlife</span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">🛍️</span>Shopping</span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">🏛️</span>Museums</span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">🏖️</span>Beaches</span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">📸</span>Instagram</span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">✨</span>AI Itineraries</span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#F7F7F7] rounded-full text-[13px] font-medium text-[#222]"><span class="text-base">📡</span>Offline</span>
        </>
      ))}
    </div>
  </section>

  <!-- AI Feature — Narrative Section -->
  <section class="py-28 md:py-36 reveal">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-[#EF3340] text-[13px] font-semibold tracking-wide uppercase">AI Itinerary</p>
          <h2 class="mt-3 text-3xl md:text-[2.75rem] font-extrabold leading-tight tracking-tight">
            Your perfect trip, planned in seconds
          </h2>
          <p class="mt-5 text-[--color-text-secondary] text-lg leading-relaxed">
            Tell us your interests, how many days you have, and your budget. Our AI generates a complete day-by-day itinerary — with timings, routes, and restaurant picks you'll actually love.
          </p>
          <ul class="mt-8 space-y-4">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#EF3340]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="w-2 h-2 rounded-full bg-[#EF3340]"></span>
              </span>
              <span class="text-[--color-text-secondary]">Solo, couple, or family — adapts to your travel style</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[--color-babu]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="w-2 h-2 rounded-full bg-[--color-babu]"></span>
              </span>
              <span class="text-[--color-text-secondary]">Swap places, regenerate, or edit on the fly</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[--color-arches]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="w-2 h-2 rounded-full bg-[--color-arches]"></span>
              </span>
              <span class="text-[--color-text-secondary]">Learns from your saves — smarter each time you use it</span>
            </li>
          </ul>
        </div>
        <!-- Itinerary card visual -->
        <div class="relative">
          <div class="bg-[#1C1C1E] rounded-[32px] p-8 hover-lift overflow-hidden" style="border: 0.5px solid rgba(255,255,255,0.1)">
            <!-- Subtle glow -->
            <div class="absolute top-0 right-0 w-40 h-40 bg-[#EF3340]/20 rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 left-0 w-32 h-32 bg-[--color-babu]/15 rounded-full blur-3xl"></div>

            <div class="relative z-10 space-y-5">
              <!-- Header -->
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                    <span class="text-lg">✨</span>
                  </div>
                  <div>
                    <p class="font-bold text-white text-sm">3-Day Singapore Trip</p>
                    <p class="text-[11px] text-white/40">AI Generated · Just now</p>
                  </div>
                </div>
                <span class="text-[10px] text-white/30 bg-white/5 px-2.5 py-1 rounded-full border border-white/10">Preview</span>
              </div>

              <!-- Itinerary days -->
              {[
                { day: 'Day 1', title: 'Marina Bay & Culture', places: '6 spots · 8hrs', color: 'bg-[#EF3340]' },
                { day: 'Day 2', title: 'Food & Hidden Gems', places: '8 spots · 7hrs', color: 'bg-[--color-arches]' },
                { day: 'Day 3', title: 'Nature & Beaches', places: '5 spots · 6hrs', color: 'bg-[--color-babu]' },
              ].map((item, i) => (
                <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-4 flex items-center gap-4 border border-white/5" style={`animation: slide-in-right 0.6s cubic-bezier(0.16,1,0.3,1) ${0.3 + i * 0.15}s forwards; opacity: 0;`}>
                  <div class={`w-10 h-10 rounded-xl ${item.color} flex items-center justify-center text-white text-xs font-bold shadow-lg`}>
                    {i + 1}
                  </div>
                  <div class="flex-1">
                    <p class="text-white text-sm font-semibold">{item.title}</p>
                    <p class="text-white/40 text-[11px] mt-0.5">{item.places}</p>
                  </div>
                  <svg class="w-4 h-4 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </div>
              ))}

              <!-- Bottom meta -->
              <div class="flex items-center justify-between pt-2">
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
                  <span class="text-[11px] text-white/40">Optimised for walking distance</span>
                </div>
                <span class="text-[11px] text-white/30">19 places total</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Must Visit Places -->
  {featuredPlaces && featuredPlaces.length > 0 && (
    <section class="py-28 md:py-36 bg-[--color-surface] reveal">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="text-[#EF3340] text-[13px] font-semibold tracking-wide uppercase">Must Visit</p>
            <h2 class="mt-3 text-3xl md:text-[2.75rem] font-extrabold leading-tight tracking-tight">
              Places you can't miss
            </h2>
          </div>
          <a href="#download" class="hidden md:block text-[13px] text-[--color-text-secondary] hover:text-[--color-text-primary] transition-colors underline underline-offset-4 decoration-[--color-border]">
            See all {placesCount}+ places
          </a>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {featuredPlaces.map((place, i) => (
            <div class="bg-white rounded-[24px] overflow-hidden hover-lift img-zoom cursor-pointer" style={`border: 0.5px solid rgba(0,0,0,0.06); animation: fade-up 0.6s cubic-bezier(0.16,1,0.3,1) ${i * 0.1}s forwards; opacity: 0;`}>
              <div class="aspect-[4/3] bg-[--color-surface] overflow-hidden">
                {place.image_url ? (
                  <img src={place.image_url} alt={place.name} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="text-4xl opacity-30">📍</span>
                  </div>
                )}
              </div>
              <div class="p-5">
                <h3 class="font-bold text-[15px]">{place.name}</h3>
                <div class="flex items-center gap-2 mt-2">
                  <span class="text-[12px] text-[--color-text-secondary]">⭐ {place.rating}</span>
                  {place.tags?.[0] && (
                    <span class="text-[11px] text-[--color-text-tertiary] bg-[--color-surface] px-2 py-0.5 rounded-full">{place.tags[0]}</span>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Features Grid -->
  <section id="features" class="py-28 md:py-36 reveal">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-[#EF3340] text-[13px] font-semibold tracking-wide uppercase">Features</p>
        <h2 class="mt-3 text-3xl md:text-[2.75rem] font-extrabold leading-tight tracking-tight">
          Built for real travellers
        </h2>
      </div>

      <div class="mt-16 grid grid-cols-2 lg:grid-cols-4 gap-3">
        <!-- AI Recommendations — large -->
        <div class="col-span-2 row-span-2 bg-[#1C1C1E] rounded-[28px] p-8 flex flex-col justify-between hover-lift overflow-hidden relative min-h-[400px]" style="border: 0.5px solid rgba(255,255,255,0.08)">
          <div class="absolute top-0 right-0 w-40 h-40 bg-[#EF3340]/20 rounded-full blur-3xl"></div>
          <div class="relative z-10">
            <div class="flex items-center gap-2 mb-5">
              <span class="text-xl text-[#EF3340]">✦</span>
              <span class="text-[10px] text-white/30 bg-white/5 px-2 py-0.5 rounded-full border border-white/10">AI Powered</span>
            </div>
            <div class="space-y-2.5">
              {[
                { place: 'Haji Lane', reason: 'Based on your love for street art', match: '94%' },
                { place: 'Tiong Bahru Market', reason: 'You saved 3 hawker spots nearby', match: '91%' },
                { place: 'Henderson Waves', reason: 'Popular with nature lovers like you', match: '87%' },
              ].map((item, i) => (
                <div class="bg-white/5 rounded-xl p-3 flex items-center gap-3 border border-white/5" style={`animation: fade-up 0.5s cubic-bezier(0.16,1,0.3,1) ${0.2 + i * 0.12}s forwards; opacity: 0;`}>
                  <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center text-sm">📍</div>
                  <div class="flex-1 min-w-0">
                    <p class="text-white text-[13px] font-semibold truncate">{item.place}</p>
                    <p class="text-white/35 text-[10px] truncate">{item.reason}</p>
                  </div>
                  <span class="text-[#00A699] text-[11px] font-bold">{item.match}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="relative z-10 mt-5">
            <h3 class="text-xl font-bold text-white">Smart Recommendations</h3>
            <p class="mt-1 text-white/50 text-sm">Learns from your saves — gets smarter every time.</p>
          </div>
        </div>

        <!-- Offline — coral -->
        <div class="col-span-1 bg-[#FDECED] rounded-[28px] p-7 flex flex-col justify-between hover-lift min-h-[190px]">
          <span class="text-3xl">📡</span>
          <div>
            <h3 class="text-[15px] font-bold text-[#222]">100% Offline</h3>
            <p class="mt-1 text-[#717171] text-[12px] leading-relaxed">No WiFi needed. Works everywhere.</p>
          </div>
        </div>

        <!-- Distance — teal -->
        <div class="col-span-1 bg-[#EDFCFB] rounded-[28px] p-7 flex flex-col justify-between hover-lift min-h-[190px]">
          <span class="text-3xl">📍</span>
          <div>
            <h3 class="text-[15px] font-bold text-[#222]">Distance Sorting</h3>
            <p class="mt-1 text-[#717171] text-[12px] leading-relaxed">Nearest gems shown first.</p>
          </div>
        </div>

        <!-- Save & Share — amber -->
        <div class="col-span-1 bg-[#FFF8E6] rounded-[28px] p-7 flex flex-col justify-between hover-lift min-h-[190px]">
          <span class="text-3xl">🗺️</span>
          <div>
            <h3 class="text-[15px] font-bold text-[#222]">Save & Share</h3>
            <p class="mt-1 text-[#717171] text-[12px] leading-relaxed">Bookmark, share, navigate.</p>
          </div>
        </div>

        <!-- 8 Guides — lavender -->
        <div class="col-span-1 bg-[#F3EEFF] rounded-[28px] p-7 flex flex-col justify-between hover-lift min-h-[190px]">
          <span class="text-3xl">📚</span>
          <div>
            <h3 class="text-[15px] font-bold text-[#222]">8 Local Guides</h3>
            <p class="mt-1 text-[#717171] text-[12px] leading-relaxed">Curated by locals, not algorithms.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Guides -->
  <section id="guides" class="py-28 md:py-36 bg-[--color-surface] reveal">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div class="md:sticky md:top-32">
          <p class="text-[#EF3340] text-[13px] font-semibold tracking-wide uppercase">Guides</p>
          <h2 class="mt-3 text-3xl md:text-[2.75rem] font-extrabold leading-tight tracking-tight">
            {guidesCount} curated collections, built by locals
          </h2>
          <p class="mt-5 text-[--color-text-secondary] text-lg leading-relaxed">
            Not another generic travel list. Each guide is researched, verified, and packed with places you won't find on the first page of Google.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {recommendations?.map((rec, i) => {
            const iconMap = {
              'Food Guide': '🍜', 'Cafe Hopping': '☕', 'Nature': '🌳',
              'Nightlife': '🍸', 'Shopping': '🛍️', 'Culture': '🏛️',
              'Beach & Islands': '🏖️', 'Photography': '📸',
            } as any;
            const icon = iconMap[rec.tag] ?? '📍';
            const count = rec.recommendation_items?.[0]?.count ?? 0;
            return (
              <div class="bg-white rounded-[20px] p-6 hover-lift cursor-pointer" style={`border: 0.5px solid rgba(0,0,0,0.04); animation: fade-up 0.6s cubic-bezier(0.16,1,0.3,1) ${i * 0.08}s forwards; opacity: 0;`}>
                <span class="text-3xl">{icon}</span>
                <p class="font-bold text-[15px] mt-3">{rec.headline}</p>
                <p class="text-[--color-text-tertiary] text-[12px] mt-1">{count} places</p>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- Download CTA -->
  <section id="download" class="py-28 md:py-36 reveal">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="relative bg-[#1C1C1E] rounded-[32px] px-8 md:px-16 py-16 md:py-24 text-center overflow-hidden" style="border: 0.5px solid rgba(255,255,255,0.06)">
        <!-- Decorative elements -->
        <div class="absolute top-0 right-0 w-[300px] h-[300px] bg-[#EF3340]/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-[200px] h-[200px] bg-[--color-babu]/10 rounded-full blur-3xl"></div>

        <div class="relative z-10">
          <h2 class="text-3xl md:text-[2.75rem] font-extrabold text-white leading-tight tracking-tight">
            Start exploring Singapore
          </h2>
          <p class="mt-4 text-white/50 text-lg max-w-lg mx-auto leading-relaxed">
            Free to download. No account required. Just open the app and discover.
          </p>
          <div class="mt-10">
            <a href="#" class="inline-block bg-[#EF3340] text-white font-semibold px-8 py-4 rounded-full text-[15px] hover:opacity-90 transition-all hover:shadow-lg hover:shadow-[#EF3340]/20">
              Download on TestFlight
            </a>
          </div>
          <p class="mt-6 text-white/25 text-[13px]">iOS only. Android coming soon.</p>
        </div>
      </div>
    </div>
  </section>

  </main>
  <!-- Footer -->
  <footer class="bg-[#1C1C1E] pt-16 pb-8">
    <div class="max-w-[1200px] mx-auto px-6">
      <!-- Top section -->
      <div class="grid md:grid-cols-4 gap-10 pb-12 border-b border-white/10">
        <!-- Brand -->
        <div class="md:col-span-2">
          <span class="text-[17px] text-white">Explore <strong class="font-extrabold text-[#EF3340]">Singapore</strong></span>
          <p class="mt-3 text-white/40 text-[14px] leading-relaxed max-w-sm">
            Your AI-powered travel companion. Discover the best of Singapore with personalised itineraries and curated local guides.
          </p>
        </div>
        <!-- Links -->
        <div>
          <p class="text-white/60 text-[12px] font-semibold uppercase tracking-wider mb-4">Product</p>
          <ul class="space-y-3">
            <li><a href="#features" class="text-white/40 text-[14px] hover:text-white transition-colors">Features</a></li>
            <li><a href="#guides" class="text-white/40 text-[14px] hover:text-white transition-colors">Guides</a></li>
            <li><a href="#download" class="text-white/40 text-[14px] hover:text-white transition-colors">Download</a></li>
          </ul>
        </div>
        <div>
          <p class="text-white/60 text-[12px] font-semibold uppercase tracking-wider mb-4">Legal</p>
          <ul class="space-y-3">
            <li><a href="#" class="text-white/40 text-[14px] hover:text-white transition-colors">Privacy Policy</a></li>
            <li><a href="#" class="text-white/40 text-[14px] hover:text-white transition-colors">Terms of Service</a></li>
            <li><a href="#" class="text-white/40 text-[14px] hover:text-white transition-colors">Contact</a></li>
          </ul>
        </div>
      </div>
      <!-- Bottom -->
      <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-white/25 text-[13px]">&copy; 2026 Explore Singapore. All rights reserved.</p>
        <p class="text-white/25 text-[13px]">Built with love in Singapore 🇸🇬</p>
      </div>
    </div>
  </footer>

  <!-- Scroll reveal + nav script -->
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Nav scroll behavior
    const nav = document.getElementById('main-nav');
    const navText = nav.querySelector('.nav-text');
    const navLinks = nav.querySelectorAll('.nav-link');
    const navBtn = nav.querySelector('.nav-btn');

    window.addEventListener('scroll', () => {
      if (window.scrollY > 100) {
        nav.style.background = 'rgba(255,255,255,0.85)';
        nav.style.backdropFilter = 'blur(20px)';
        nav.style.borderBottom = '0.5px solid rgba(0,0,0,0.06)';
        navText.style.color = '#222';
        navLinks.forEach(l => { l.style.color = '#717171'; });
        navBtn.style.background = '#222';
        navBtn.style.color = '#fff';
      } else {
        nav.style.background = 'transparent';
        nav.style.backdropFilter = 'none';
        nav.style.borderBottom = 'none';
        navText.style.color = '#fff';
        navLinks.forEach(l => { l.style.color = 'rgba(255,255,255,0.6)'; });
        navBtn.style.background = '#fff';
        navBtn.style.color = '#222';
      }
    });
  </script>
</Layout>
