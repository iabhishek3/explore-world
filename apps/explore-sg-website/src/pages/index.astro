---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

const { data: recommendations } = await supabase
  .from('recommendations')
  .select('id, slug, headline, tag, description, image_url, recommendation_items(count)')
  .order('sort_order');

const { data: featuredPlaces } = await supabase
  .from('places')
  .select('id, name, slug, image_url, rating, tags, address')
  .eq('is_featured', true)
  .limit(6);

const { count: placesCount } = await supabase
  .from('places')
  .select('*', { count: 'exact', head: true });

const guidesCount = recommendations?.length ?? 0;
---

<Layout>
  <main>

  <!-- Navigation -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="h-[72px] flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-[#EF3340] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="white"><path d="M128,16a88.1,88.1,0,0,0-88,88c0,75.3,80,132.17,83.36,134.55a8,8,0,0,0,9.28,0C136,236.17,216,179.3,216,104A88.1,88.1,0,0,0,128,16Zm0,56a32,32,0,1,1-32,32A32,32,0,0,1,128,72Z"></path></svg>
          </div>
          <span class="text-[17px] font-bold text-[#1a1a1a]">Explore <span class="text-[#EF3340]">Singapore</span></span>
