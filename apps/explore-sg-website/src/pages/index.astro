  <script>
    // Nav scroll behavior
    const nav = document.getElementById('main-nav');
    function updateNav() {
      if (window.scrollY > 10) {
        nav.classList.add('nav-scrolled');
      } else {
        nav.classList.remove('nav-scrolled');
      }
    }
    updateNav();
    window.addEventListener('scroll', updateNav, { passive: true });

    // Full-width submenu
    const discoverTrigger = document.getElementById('discover-trigger');
    const discoverPanel = document.getElementById('discover-panel');
    const discoverChevron = document.getElementById('discover-chevron');
    let panelTimeout: any;
    let isOpen = false;

    function openPanel() {
      clearTimeout(panelTimeout);
      discoverPanel?.classList.remove('hidden');
      discoverPanel?.classList.add('animate-dropdown');
      discoverChevron?.style.setProperty('transform', 'rotate(180deg)');
      isOpen = true;
    }

    function closePanel() {
      panelTimeout = setTimeout(() => {
        discoverPanel?.classList.add('hidden');
        discoverPanel?.classList.remove('animate-dropdown');
        discoverChevron?.style.setProperty('transform', 'rotate(0deg)');
        isOpen = false;
      }, 100);
    }

    discoverTrigger?.addEventListener('mouseenter', openPanel);
    discoverTrigger?.addEventListener('click', () => { isOpen ? closePanel() : openPanel(); });
    discoverPanel?.addEventListener('mouseenter', () => clearTimeout(panelTimeout));
    discoverPanel?.addEventListener('mouseleave', closePanel);
    discoverTrigger?.addEventListener('mouseleave', closePanel);

    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });

    // Close mobile menu on link click
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
      });
    });

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('section').forEach(el => {
      el.classList.add('reveal-section');
      observer.observe(el);
    });
  </script>
</Layout>
