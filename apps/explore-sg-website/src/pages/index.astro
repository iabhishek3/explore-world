      <a href="/places" class="block text-[15px] text-[#555] hover:text-[#1a1a1a] py-2.5 pl-3 border-l-2 border-[#f0f0f0]">Places</a>
      <a href="/things-to-do" class="block text-[15px] text-[#555] hover:text-[#1a1a1a] py-2.5 pl-3 border-l-2 border-[#f0f0f0]">Things to Do</a>
      <a href="/singapore-itinerary" class="block text-[15px] text-[#555] hover:text-[#1a1a1a] py-2.5 pl-3 border-l-2 border-[#f0f0f0]">3-Day Itinerary</a>
      <div class="border-t border-[#f5f5f5] my-2"></div>
      <a href="/guides" class="block text-[15px] text-[#555] hover:text-[#1a1a1a] py-3">Guides</a>
      <a href="/about" class="block text-[15px] text-[#555] hover:text-[#1a1a1a] py-3">About</a>
      <div class="pt-3">
        <a href="https://app.exploresg.info" class="block text-center text-[14px] font-semibold text-white bg-[#1a1a1a] py-3 rounded-xl">Plan Your Trip</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-[120px] pb-16 md:pt-[140px] md:pb-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-[720px] mx-auto">
        <p class="text-[13px] font-medium text-[#999] uppercase tracking-wide mb-5">Free AI-Powered Trip Planner</p>
        <h1 class="text-[clamp(2rem,5vw,3.25rem)] font-extrabold leading-[1.12] tracking-[-0.025em] text-[#1a1a1a]">
          Plan your Singapore itinerary in minutes
        </h1>
        <p class="mt-5 text-[#666] text-[17px] leading-[1.65] max-w-[560px] mx-auto">
          From Marina Bay to hawker centres, Sentosa to hidden neighbourhood cafes — browse {placesCount}+ curated places, build your day-by-day plan, and export it. Free, no sign-up.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="https://app.exploresg.info" class="inline-flex items-center gap-2.5 bg-[#EF3340] text-white font-semibold px-7 py-3.5 rounded-full text-[15px] hover:bg-[#d62b36] transition-colors shadow-[0_2px_12px_rgba(239,51,64,0.25)]">
            Start Planning — It's Free
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="currentColor"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69l-58.35-58.34a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path></svg>
          </a>
          <a href="#how" class="text-[14px] font-medium text-[#666] hover:text-[#1a1a1a] underline underline-offset-4 decoration-[#ddd] hover:decoration-[#999] transition-colors">
            How it works
          </a>
        </div>
      </div>

      <!-- Browser Mockup -->
      <div class="mt-16 relative max-w-[1050px] mx-auto">
        <div class="rounded-xl overflow-hidden border border-[#e0e0e0] shadow-[0_8px_60px_rgba(0,0,0,0.08),0_2px_8px_rgba(0,0,0,0.04)]">
          <!-- Browser chrome -->
          <div class="bg-[#f8f8f8] px-4 py-3 flex items-center gap-3 border-b border-[#e8e8e8]">
            <div class="flex gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#FFBD2E]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#28CA41]"></span>
            </div>
            <div class="flex-1 max-w-[320px] mx-auto bg-white rounded-md px-3 py-1.5 text-[11px] text-[#999] text-center border border-[#e8e8e8]">
              app.exploresg.info
            </div>
            <div class="w-[52px]"></div>
          </div>
          <!-- Screenshot -->
          <img
            src="/app-preview.png"
            alt="Explore Singapore web application — interactive trip planner with map and itinerary builder"
            class="w-full h-auto hidden md:block"
          />
          <img
            src="/app-preview-mobile.png"
            alt="Explore Singapore mobile view"
            class="w-full max-w-[320px] mx-auto h-auto md:hidden py-4"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Logos / Trust -->
  <section class="py-10 border-y border-[#f0f0f0]">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-4">
        <div class="flex items-center gap-2.5 text-[#888]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M128,16a88.1,88.1,0,0,0-88,88c0,75.3,80,132.17,83.36,134.55a8,8,0,0,0,9.28,0C136,236.17,216,179.3,216,104A88.1,88.1,0,0,0,128,16Zm0,56a32,32,0,1,1-32,32A32,32,0,0,1,128,72Z"></path></svg>
          <span class="text-[14px] font-medium">{placesCount}+ Places</span>
        </div>
        <div class="w-px h-4 bg-[#e0e0e0] hidden sm:block"></div>
        <div class="flex items-center gap-2.5 text-[#888]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M224,48H160a40,40,0,0,0-32,16A40,40,0,0,0,96,48H32A16,16,0,0,0,16,64V192a16,16,0,0,0,16,16H96a24,24,0,0,1,24,24,8,8,0,0,0,16,0,24,24,0,0,1,24-24h64a16,16,0,0,0,16-16V64A16,16,0,0,0,224,48ZM96,192H32V64H96a24,24,0,0,1,24,24V200A39.81,39.81,0,0,0,96,192Zm128,0H160a39.81,39.81,0,0,0-24,8V88a24,24,0,0,1,24-24h64Z"></path></svg>
          <span class="text-[14px] font-medium">{guidesCount} Local Guides</span>
        </div>
        <div class="w-px h-4 bg-[#e0e0e0] hidden sm:block"></div>
        <div class="flex items-center gap-2.5 text-[#888]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm45.66,109.66-32,32a8,8,0,0,1-11.32-11.32L148.69,136H88a8,8,0,0,1,0-16h60.69l-18.35-18.34a8,8,0,0,1,11.32-11.32l32,32A8,8,0,0,1,173.66,133.66Z"></path></svg>
          <span class="text-[14px] font-medium">No Sign-up</span>
        </div>
        <div class="w-px h-4 bg-[#e0e0e0] hidden sm:block"></div>
        <div class="flex items-center gap-2.5 text-[#888]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Zm0,160H40V56H216V200ZM176,88a48,48,0,0,1-96,0,8,8,0,0,1,16,0,32,32,0,0,0,64,0,8,8,0,0,1,16,0Zm37.66,82.34a8,8,0,0,1,0,11.32l-24,24a8,8,0,0,1-11.32-11.32L190.69,182l-12.35-12.34a8,8,0,0,1,11.32-11.32Z"></path></svg>
          <span class="text-[14px] font-medium">100% Free</span>
        </div>
      </div>
    </div>
  </section>

  <!-- How it Works -->
  <section id="how" class="py-20 md:py-28">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-[560px] mx-auto mb-16">
        <p class="text-[13px] font-semibold text-[#EF3340] mb-3">HOW IT WORKS</p>
        <h2 class="text-[1.75rem] md:text-[2.25rem] font-extrabold leading-[1.2] tracking-[-0.02em] text-[#1a1a1a]">
          From browsing to booking-ready in minutes
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 md:gap-10">
        <!-- Step 1 -->
        <div class="text-center md:text-left">
          <div class="w-12 h-12 rounded-2xl bg-[#f5f5f5] flex items-center justify-center mx-auto md:mx-0 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 256 256" fill="#1a1a1a"><path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"></path></svg>
          </div>
          <div class="text-[11px] font-bold text-[#999] uppercase tracking-wider mb-2">Step 1</div>
          <h3 class="text-[18px] font-bold text-[#1a1a1a] mb-2">Discover places</h3>
          <p class="text-[14px] text-[#666] leading-relaxed">
            Browse {placesCount}+ spots — hawker centres, rooftop bars, nature trails, museums, and cafes. Filter by what you're in the mood for. Every place is rated and visited by locals.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="text-center md:text-left">
          <div class="w-12 h-12 rounded-2xl bg-[#f5f5f5] flex items-center justify-center mx-auto md:mx-0 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 256 256" fill="#1a1a1a"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208ZM80,80A8,8,0,0,1,88,72h24a8,8,0,0,1,0,16H88A8,8,0,0,1,80,80Zm0,48a8,8,0,0,1,8-8h80a8,8,0,0,1,0,16H88A8,8,0,0,1,80,128Zm0,48a8,8,0,0,1,8-8h80a8,8,0,0,1,0,16H88A8,8,0,0,1,80,176Z"></path></svg>
          </div>
          <div class="text-[11px] font-bold text-[#999] uppercase tracking-wider mb-2">Step 2</div>
          <h3 class="text-[18px] font-bold text-[#1a1a1a] mb-2">Build your itinerary</h3>
          <p class="text-[14px] text-[#666] leading-relaxed">
            Add places to Day 1, Day 2, Day 3. Drag to reorder. The map shows your route so you don't waste time criss-crossing the island.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="text-center md:text-left">
          <div class="w-12 h-12 rounded-2xl bg-[#f5f5f5] flex items-center justify-center mx-auto md:mx-0 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 256 256" fill="#1a1a1a"><path d="M213.66,82.34l-56-56A8,8,0,0,0,152,24H56A16,16,0,0,0,40,40V216a16,16,0,0,0,16,16H200a16,16,0,0,0,16-16V88A8,8,0,0,0,213.66,82.34ZM160,51.31,188.69,80H160ZM200,216H56V40h88V88a8,8,0,0,0,8,8h48V216Zm-40-64a8,8,0,0,1-8,8H136v16a8,8,0,0,1-16,0V160H104a8,8,0,0,1,0-16h16V128a8,8,0,0,1,16,0v16h16A8,8,0,0,1,160,152Z"></path></svg>
          </div>
          <div class="text-[11px] font-bold text-[#999] uppercase tracking-wider mb-2">Step 3</div>
          <h3 class="text-[18px] font-bold text-[#1a1a1a] mb-2">Export & go</h3>
          <p class="text-[14px] text-[#666] leading-relaxed">
            Download your itinerary as a PDF with every address and a Google Maps link for each stop. Works offline — open it on the MRT or at the hawker centre.
          </p>
        </div>
      </div>

      <div class="mt-14 text-center">
        <a href="https://app.exploresg.info" class="inline-flex items-center gap-2 text-[14px] font-semibold text-[#EF3340] hover:text-[#d62b36] transition-colors">
          Try it now — takes 2 minutes
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69l-58.35-58.34a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 md:py-28 bg-[#fafafa] border-y border-[#f0f0f0]">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center max-w-[560px] mx-auto mb-16">
        <p class="text-[13px] font-semibold text-[#EF3340] mb-3">FEATURES</p>
        <h2 class="text-[1.75rem] md:text-[2.25rem] font-extrabold leading-[1.2] tracking-[-0.02em] text-[#1a1a1a]">
          Built for how you actually travel
        </h2>
        <p class="mt-3 text-[#666] text-[16px]">No bloat. No ads. Just a really good planning tool.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Feature 1: AI -->
