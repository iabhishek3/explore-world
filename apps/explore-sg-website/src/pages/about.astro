---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Explore Singapore">
  <!-- Nav -->
  <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-[#f0f0f0]">
    <div class="max-w-[1120px] mx-auto px-6 h-[64px] flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-md bg-[#EF3340] flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="white"><path d="M128,16a88.1,88.1,0,0,0-88,88c0,75.3,80,132.17,83.36,134.55a8,8,0,0,0,9.28,0C136,236.17,216,179.3,216,104A88.1,88.1,0,0,0,128,16Zm0,56a32,32,0,1,1-32,32A32,32,0,0,1,128,72Z"></path></svg>
        </div>
        <span class="text-[16px] font-bold text-[#1a1a1a]">Explore <span class="text-[#EF3340]">Singapore</span></span>
      </a>
      <div class="flex items-center gap-4">
        <div class="hidden md:flex items-center gap-1">
          <button id="discover-trigger" class="text-[14px] text-[#555] hover:text-[#1a1a1a] px-4 py-2 rounded-lg hover:bg-[#f5f5f5] transition-all inline-flex items-center gap-1.5 cursor-pointer">
            Discover
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 256 256" fill="currentColor" class="mt-px transition-transform" id="discover-chevron"><path d="M213.66,101.66l-80,80a8,8,0,0,1-11.32,0l-80-80A8,8,0,0,1,53.66,90.34L128,164.69l74.34-74.35a8,8,0,0,1,11.32,11.32Z"></path></svg>
          </button>
          <a href="/guides" class="text-[14px] text-[#555] hover:text-[#1a1a1a] px-4 py-2 rounded-lg hover:bg-[#f5f5f5] transition-all">Guides</a>
          <a href="/about" class="text-[14px] text-[#555] hover:text-[#1a1a1a] px-4 py-2 rounded-lg hover:bg-[#f5f5f5] transition-all">About</a>
        </div>
        <div class="hidden md:flex items-center gap-3">
          <a href="https://app.exploresg.info" class="text-[13px] font-semibold text-white bg-[#1a1a1a] px-5 py-2.5 rounded-full hover:bg-[#333] transition-colors">
            Open Planner
          </a>
        </div>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden w-10 h-10 flex items-center justify-center rounded-lg hover:bg-[#f5f5f5] transition-colors" aria-label="Menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="#1a1a1a"><path d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM40,72H216a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM216,184H40a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16Z"></path></svg>
        </button>
      </div>
    </div>
    <!-- Full-width Submenu -->
    <div id="discover-panel" class="hidden bg-white border-t border-[#f0f0f0]">
      <div class="max-w-[1200px] mx-auto px-6 py-6">
        <div class="grid grid-cols-3 gap-6">
          <a href="/places" class="group flex gap-4 p-4 rounded-xl hover:bg-[#f8f8f8] transition-colors">
            <div class="w-10 h-10 rounded-lg bg-[#f5f5f5] flex items-center justify-center shrink-0 group-hover:bg-[#eee] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 256 256" fill="#1a1a1a"><path d="M128,16a88.1,88.1,0,0,0-88,88c0,75.3,80,132.17,83.36,134.55a8,8,0,0,0,9.28,0C136,236.17,216,179.3,216,104A88.1,88.1,0,0,0,128,16Zm0,56a32,32,0,1,1-32,32A32,32,0,0,1,128,72Z"></path></svg>
            </div>
            <div>
              <p class="text-[14px] font-semibold text-[#1a1a1a] group-hover:text-[#EF3340] transition-colors">Places to Visit</p>
              <p class="text-[13px] text-[#888] mt-0.5">100+ curated spots across Singapore</p>
            </div>
          </a>
          <a href="/things-to-do" class="group flex gap-4 p-4 rounded-xl hover:bg-[#f8f8f8] transition-colors">
            <div class="w-10 h-10 rounded-lg bg-[#f5f5f5] flex items-center justify-center shrink-0 group-hover:bg-[#eee] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 256 256" fill="#1a1a1a"><path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"></path></svg>
            </div>
            <div>
              <p class="text-[14px] font-semibold text-[#1a1a1a] group-hover:text-[#EF3340] transition-colors">Things to Do</p>
              <p class="text-[13px] text-[#888] mt-0.5">Activities, attractions & hidden gems</p>
            </div>
          </a>
          <a href="/singapore-itinerary" class="group flex gap-4 p-4 rounded-xl hover:bg-[#f8f8f8] transition-colors">
            <div class="w-10 h-10 rounded-lg bg-[#f5f5f5] flex items-center justify-center shrink-0 group-hover:bg-[#eee] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 256 256" fill="#1a1a1a"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208ZM80,80A8,8,0,0,1,88,72h24a8,8,0,0,1,0,16H88A8,8,0,0,1,80,80Zm0,48a8,8,0,0,1,8-8h80a8,8,0,0,1,0,16H88A8,8,0,0,1,80,128Zm0,48a8,8,0,0,1,8-8h80a8,8,0,0,1,0,16H88A8,8,0,0,1,80,176Z"></path></svg>
            </div>
            <div>
              <p class="text-[14px] font-semibold text-[#1a1a1a] group-hover:text-[#EF3340] transition-colors">3-Day Itinerary</p>
              <p class="text-[13px] text-[#888] mt-0.5">Ready-made day-by-day plan</p>
            </div>
          </a>
        </div>
      </div>
    </div>
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-[#f0f0f0] px-6 py-4 space-y-1">
      <a href="/places" class="block text-[15px] text-[#555] hover:text-[#1a1a1a] py-3 border-b border-[#f5f5f5]">Places</a>
      <a href="/guides" class="block text-[15px] text-[#555] hover:text-[#1a1a1a] py-3 border-b border-[#f5f5f5]">Guides</a>
      <a href="/about" class="block text-[15px] text-[#555] hover:text-[#1a1a1a] py-3 border-b border-[#f5f5f5]">About</a>
      <div class="pt-3">
        <a href="https://app.exploresg.info" class="block text-center text-[14px] font-semibold text-white bg-[#1a1a1a] py-3 rounded-xl">Plan Your Trip</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="py-16 md:py-24">
    <div class="max-w-[680px] mx-auto px-6">
      <h1 class="text-[2.5rem] font-bold text-[#222] leading-tight mb-4">Built for travelers, by locals</h1>
      <p class="text-[16px] text-[#555] leading-relaxed">A free Singapore trip planner made by people who actually live here. We know which hawker stall has the queue for a reason, which MRT exit saves you 10 minutes, and why you should skip the tourist trap and walk one street over.</p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-16 md:py-24 bg-[#fafafa]">
    <div class="max-w-[680px] mx-auto px-6">
      <h2 class="text-[1.75rem] font-bold text-[#222] mb-8">Why we built this</h2>
      <div class="space-y-6 text-[16px] text-[#555] leading-relaxed">
        <p>We kept running into the same problem. Friends visiting Singapore would ask us for recommendations, and we would end up sending a chaotic mix of Google Maps links, screenshots of hawker menus, and half-remembered MRT directions. Every existing travel tool was either bloated with ads, gated behind a login, or scraped together from outdated listings.</p>
        <p>So we built the thing we wished existed: a focused, fast trip planner that actually understands how Singapore works. Where the neighborhoods connect. Which hawker centres are worth the queue. What you can realistically fit into a day without spending half of it on transfers.</p>
        <p>No downloads. No sign-ups. Just open it and start planning. We think travel tools should get out of the way and let you get excited about the trip itself.</p>
      </div>
    </div>
  </section>

  <!-- What makes us different -->
  <section class="py-16 md:py-24">
    <div class="max-w-[680px] mx-auto px-6">
      <h2 class="text-[1.75rem] font-bold text-[#222] mb-10">What makes us different</h2>
      <div class="space-y-10">
        <div>
          <h3 class="text-[1.125rem] font-semibold text-[#222] mb-2">Curated, not scraped</h3>
          <p class="text-[16px] text-[#555] leading-relaxed">Every place in our database has been vetted. We do not scrape thousands of listings and dump them on a map. We pick places worth your limited time and tell you why they matter.</p>
        </div>
        <div>
          <h3 class="text-[1.125rem] font-semibold text-[#222] mb-2">AI that understands geography</h3>
          <p class="text-[16px] text-[#555] leading-relaxed">Our planner does not just list attractions — it builds routes that make spatial sense. It knows that Tiong Bahru and Chinatown are a short walk apart, and that you should not cross the island twice in one afternoon.</p>
        </div>
        <div>
          <h3 class="text-[1.125rem] font-semibold text-[#222] mb-2">Free forever</h3>
          <p class="text-[16px] text-[#555] leading-relaxed">No premium tiers. No "unlock full itinerary" paywalls. We built this because Singapore deserves a great trip planner, not because we needed a revenue model.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 md:py-24 bg-[#fafafa]">
    <div class="max-w-[680px] mx-auto px-6">
      <h2 class="text-[1.75rem] font-bold text-[#222] mb-6">Who we are</h2>
      <p class="text-[16px] text-[#555] leading-relaxed">A small team based in Singapore. We eat at the same hawker centres we recommend, walk the same trails, and know which "hidden gem" is actually hidden versus just poorly signposted. We built Explore Singapore because every friend who visits deserves better than a generic TripAdvisor list — they deserve the itinerary we'd plan for them over coffee.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24">
    <div class="max-w-[680px] mx-auto px-6 text-center">
      <h2 class="text-[1.75rem] font-bold text-[#222] mb-4">Ready to plan your trip?</h2>
      <p class="text-[16px] text-[#555] mb-8">No sign-up required. Open the planner and start building your itinerary.</p>
      <a
        href="https://app.exploresg.info"
        class="inline-block px-8 py-3 bg-[#EF3340] text-white font-semibold text-[16px] rounded-lg no-underline hover:opacity-90 transition-opacity"
      >Try the planner</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-[#f0f0f0] pt-16 pb-8">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid md:grid-cols-12 gap-8 pb-12">
        <div class="md:col-span-5">
          <a href="/" class="flex items-center gap-2 mb-4">
            <div class="w-7 h-7 rounded-md bg-[#EF3340] flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="white"><path d="M128,16a88.1,88.1,0,0,0-88,88c0,75.3,80,132.17,83.36,134.55a8,8,0,0,0,9.28,0C136,236.17,216,179.3,216,104A88.1,88.1,0,0,0,128,16Zm0,56a32,32,0,1,1-32,32A32,32,0,0,1,128,72Z"></path></svg>
            </div>
            <span class="text-[16px] font-bold text-[#1a1a1a]">Explore <span class="text-[#EF3340]">Singapore</span></span>
          </a>
          <p class="text-[14px] text-[#888] leading-relaxed max-w-[320px]">
            Free AI-powered trip planner for Singapore. Curated places, local guides, and an interactive itinerary builder.
          </p>
        </div>
        <div class="md:col-span-2">
          <p class="text-[12px] font-semibold text-[#1a1a1a] uppercase tracking-wider mb-4">Product</p>
          <ul class="space-y-3">
            <li><a href="/places" class="text-[14px] text-[#888] hover:text-[#1a1a1a] transition-colors">Places</a></li>
            <li><a href="/guides" class="text-[14px] text-[#888] hover:text-[#1a1a1a] transition-colors">Guides</a></li>
            <li><a href="https://app.exploresg.info" class="text-[14px] text-[#888] hover:text-[#1a1a1a] transition-colors">Open Planner</a></li>
          </ul>
        </div>
        <div class="md:col-span-2">
          <p class="text-[12px] font-semibold text-[#1a1a1a] uppercase tracking-wider mb-4">Company</p>
          <ul class="space-y-3">
            <li><a href="/about" class="text-[14px] text-[#888] hover:text-[#1a1a1a] transition-colors">About</a></li>
            <li><a href="/privacy" class="text-[14px] text-[#888] hover:text-[#1a1a1a] transition-colors">Privacy</a></li>
            <li><a href="/terms" class="text-[14px] text-[#888] hover:text-[#1a1a1a] transition-colors">Terms</a></li>
          </ul>
        </div>
        <div class="md:col-span-3">
          <p class="text-[12px] font-semibold text-[#1a1a1a] uppercase tracking-wider mb-4">Open the app</p>
          <a href="https://app.exploresg.info" class="inline-flex items-center gap-2 text-[13px] font-semibold text-white bg-[#1a1a1a] px-5 py-2.5 rounded-full hover:bg-[#333] transition-colors">
            Plan Your Trip
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="currentColor"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69l-58.35-58.34a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path></svg>
          </a>
        </div>
      </div>
      <div class="pt-8 border-t border-[#f0f0f0] flex flex-col md:flex-row items-center justify-between gap-3">
        <p class="text-[13px] text-[#ccc]">&copy; 2026 Explore Singapore</p>
        <p class="text-[13px] text-[#ccc]">Made in Singapore</p>
      </div>
    </div>
  </footer>

  <script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
    });

    // Full-width submenu
    const discoverTrigger = document.getElementById('discover-trigger');
    const discoverPanel = document.getElementById('discover-panel');
    const discoverChevron = document.getElementById('discover-chevron');
    let panelTimeout;
    let isOpen = false;

    function openPanel() {
      clearTimeout(panelTimeout);
      discoverPanel?.classList.remove('hidden');
      discoverPanel?.classList.add('animate-dropdown');
      discoverChevron?.style.setProperty('transform', 'rotate(180deg)');
      isOpen = true;
    }

    function closePanel() {
      panelTimeout = setTimeout(() => {
        discoverPanel?.classList.add('hidden');
        discoverPanel?.classList.remove('animate-dropdown');
        discoverChevron?.style.setProperty('transform', 'rotate(0deg)');
        isOpen = false;
      }, 100);
    }

    discoverTrigger?.addEventListener('mouseenter', openPanel);
    discoverTrigger?.addEventListener('click', () => { isOpen ? closePanel() : openPanel(); });
    discoverPanel?.addEventListener('mouseenter', () => clearTimeout(panelTimeout));
    discoverPanel?.addEventListener('mouseleave', closePanel);
    discoverTrigger?.addEventListener('mouseleave', closePanel);
  </script>
</Layout>
